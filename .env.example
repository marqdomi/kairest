# ═══════════════════════════════════════
# KaiRest POS — Variables de Entorno
# Copia este archivo como .env y edita
# ═══════════════════════════════════════

# 🔑 OBLIGATORIO — genera con: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# 🗄️ Base de datos (no cambiar si usas el Docker Compose incluido)
POSTGRES_PASSWORD=kairest_secret_2026

# 🌐 Puerto de la app (default 5005)
APP_PORT=5005

# 🔗 Orígenes permitidos para CORS (separar con comas si hay varios)
CORS_ORIGINS=http://localhost:5005

# 📦 Imagen Docker (no cambiar excepto para versiones específicas)
# KAIREST_IMAGE=ghcr.io/marqdomi/kairest:latest
